#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: show-task-run-log <task-id>" >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "Error: jq is required for show-task-run-log." >&2
  exit 1
fi

if ! command -v column >/dev/null 2>&1; then
  echo "Error: column is required for show-task-run-log." >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TASK_ID="$1"

{
  printf 'created_at\tauthor\tverb\tmessage\n'
  python3 "$SCRIPT_DIR/task.py" show-run-log "$TASK_ID" \
    | jq -r '.[] | [.created_at, (.author // "-"), (.verb // "-"), .message] | @tsv'
} | column -t -s $'\t'

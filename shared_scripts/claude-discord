#!/bin/bash

RESTART_FILE="${CLAUDE_DISCORD_RESTART_FILE:-$HOME/.claude-discord-restart}"
export CLAUDE_DISCORD_RESTART_FILE="$RESTART_FILE"
POLL_INTERVAL=2

CLAUDE_PID=""

cleanup() {
    [ -n "$CLAUDE_PID" ] && kill "$CLAUDE_PID" 2>/dev/null && wait "$CLAUDE_PID" 2>/dev/null
    exit 0
}
trap cleanup INT TERM

INITIAL_PROMPT=""

while true; do
    CMD=(claude --channels plugin:discord@claude-plugins-official "$@")
    [ -n "$INITIAL_PROMPT" ] && CMD+=(-- "$INITIAL_PROMPT")
    echo "[claude-discord] Starting: $(printf '%q ' "${CMD[@]}")"
    "${CMD[@]}" &
    CLAUDE_PID=$!
    INITIAL_PROMPT=""

    RESTART=0
    RESTART_PROMPT=""
    while true; do
        if [ -f "$RESTART_FILE" ]; then
            RESTART_PROMPT=$(cat "$RESTART_FILE")
            rm -f "$RESTART_FILE"
            kill "$CLAUDE_PID" 2>/dev/null
            wait "$CLAUDE_PID" 2>/dev/null
            CLAUDE_PID=""
            RESTART=1
            break
        fi
        if ! kill -0 "$CLAUDE_PID" 2>/dev/null; then
            CLAUDE_PID=""
            break
        fi
        sleep "$POLL_INTERVAL"
    done

    [ "$RESTART" -eq 0 ] && break
    INITIAL_PROMPT="$RESTART_PROMPT"
done
